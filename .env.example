# === MailKite Auth (required) ===
MAILKITE_API_URL=https://api.mailkite.dev
MAILKITE_API_KEY=               # From mailkite.dev dashboard → API Keys
AUTH_SECRET=                    # openssl rand -base64 32

# Default "from" for all app email (welcome + contact). IMPORTANT: if your
# MAILKITE_API_KEY is scoped to a single domain, this address MUST be on that
# domain, or sends fail with 403 key_scope. e.g. noreply@your-domain.com
MAILKITE_FROM=noreply@mailkite.dev

# === Contact form ===
CONTACT_EMAIL=                  # Where /contact submissions are delivered (your inbox)
CONTACT_FROM=                   # Optional — overrides MAILKITE_FROM for /contact only (same scope rule applies)

# === OAuth providers (optional — enables social login buttons) ===
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# === Magic Link (optional) ===
MAILKITE_MAGIC_LINK=false

# === Database (choose one) ===
POSTGRES_URL=                  # PostgreSQL (Neon, Supabase, Vercel Postgres)
# OR
SQLITE_DATABASE_URL=           # Local SQLite / Turso
# D1 via wrangler binding (no env var in prod)

# === Stripe (from saas-starter) ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
BASE_URL=http://localhost:3000
